# Runalyze Personal API (Settings → Personal API). Read access requires Supporter/Premium scopes.
RUNALYZE_TOKEN=

# Optional: override activity collection paths (comma-separated, relative to https://runalyze.com/api/v1)
# RUNALYZE_ACTIVITY_URLS=/activities,/sport-activities
# RUNALYZE_WELLNESS_URLS=/days,/wellness

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gmail (App Password: Google Account → Security → 2-Step Verification → App passwords)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# GitHub backup (repo must exist; token needs repo scope)
GITHUB_TOKEN=
GITHUB_REPO=your-username/your-private-repo

# Who receives the daily HTML email (05:30 UTC)
RECIPIENT_EMAIL=

# Optional: where metrics.json lives (default: ./data/metrics.json)
# DATA_DIR=/var/data
# METRICS_FILE=/var/data/metrics.json

# Set to 1 to turn off APScheduler (e.g. local dev without duplicate jobs)
# DISABLE_SCHEDULER=0
